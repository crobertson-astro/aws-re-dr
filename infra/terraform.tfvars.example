// -----------------------------------------------------------------------------
// Required — fill these in before running terraform apply
// -----------------------------------------------------------------------------
aws_profile     = "<your-aws-sso-profile>"  // e.g. "my-company-dev"
aws_account_id  = "<your-aws-account-id>"   // e.g. "123456789012"
primary_region  = "us-west-2"               // active region
failover_region = "us-west-1"               // DR replica region
// NOTE: If you change failover_region, you must ALSO update the hardcoded
// `dr_region` in infra/main.tf (astro_cluster.this). The astro provider
// rejects variable references there — see the comment in main.tf for context.
project_name    = "<your-project-name>"     // e.g. "astro-re"
environment     = "<your-environment>"      // e.g. "dev"
owner           = "<your-team-name>"        // e.g. "Data Engineering"

// -----------------------------------------------------------------------------
// Astro — required
// -----------------------------------------------------------------------------
astro_organization_id = "<your-astro-organization-id>"
workspace_id          = "<your-astro-workspace-id>"
deployment_name       = "<your-deployment-name>"  // e.g. "aws-re-dr-deployment"

// Astro cluster — pick ONE of the two options below:
//
// Option A (default): let Terraform create a new DR-enabled Astro cluster.
// Set cluster_name and leave existing_cluster_id unset.
cluster_name = "<your-cluster-name>"  // e.g. "aws-re-dr-cluster"
//
// Option B (bring-your-own-cluster): attach the deployment to a pre-existing
// Astro cluster. Set existing_cluster_id and comment out cluster_name above.
// The other cluster_* variables below are ignored in this mode.
# existing_cluster_id = "<your-existing-astro-cluster-id>"

// -----------------------------------------------------------------------------
// Optional — override here if needed
// -----------------------------------------------------------------------------
# vpc_cidr  = "10.0.0.0/24"   // applied to both regions
# az_count  = 2               // applied to both regions

// -----------------------------------------------------------------------------
// Git DAG Bundle (optional) — uncomment and fill in to enable
// -----------------------------------------------------------------------------
# git_repo_url = "https://github.com/your-org/your-dags.git"
# git_username = "your-github-username"
# git_pat      = "ghp_xxxxxxxxxxxxxxxxxxxx"
git_branch   = "main"
dag_subdir   = "dags"
